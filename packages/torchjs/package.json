{
  "name": "torchjs",
  "version": "0.1.0",
  "description": "PyTorch-style neural network operations for JavaScript - torch.nn.functional equivalent",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "author": "Sven",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/pydatajs"
  },
  "keywords": [
    "pytorch",
    "neural-network",
    "deep-learning",
    "cnn",
    "convolution",
    "wasm"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:wasm": "wasm-pack build crates/torchjs-wasm --target web --out-dir ../../pkg"
  },
  "dependencies": {
    "numpyjs": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@webgpu/types": "^0.1.69",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "files": [
    "dist",
    "pkg"
  ]
}

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "numpyjs": ["../numpyjs/src/index.ts"]
    },
    "noUncheckedIndexedAccess": false,
    "noUnusedParameters": false,
    "noUnusedLocals": false,
    "types": ["@webgpu/types"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
